# Copy this file to .env.development, .env.staging, or .env.production
# and fill in the values for your environment.
# Never commit real credentials to version control.

# Environment name: development | staging | production
APP_ENV=development

# Supabase project URL (found in: Project Settings > API > Project URL)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (found in: Project Settings > API > anon public)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

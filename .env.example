# ─── Supabase ────────────────────────────────────────────────────────────────
# https://supabase.com/dashboard → プロジェクト → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ─── RevenueCat ──────────────────────────────────────────────────────────────
# 取得手順:
#   1. https://app.revenuecat.com でアカウント作成
#   2. New Project → App Name: "タスクリー"
#   3. iOS App: Bundle ID = com.yourname.taskly → API Key をコピー (appl_で始まる)
#   4. Android App: Package = com.yourname.taskly → API Key をコピー (goog_で始まる)
#   5. Entitlement ID: "premium" (billing.ts の ENTITLEMENT_PREMIUM と一致させること)
#   6. Product を App Store Connect / Google Play Console で作成してから
#      RevenueCat の Products に登録する
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Sentry ──────────────────────────────────────────────────────────────────
# 取得手順:
#   1. https://sentry.io でアカウント作成
#   2. New Project → React Native → Project Name: "taskly"
#   3. DSN を Settings → SDK Setup → DSN からコピー
#   4. App.tsx の SENTRY_DSN がこの値を読み込む
EXPO_PUBLIC_SENTRY_DSN=https://xxxx@xxxxxx.ingest.sentry.io/xxxxx
